@{
    ViewData["Title"] = "Home Page";
 

 
    ViewBag.Title = "Generador de Documentación";
}

<h2>Generador Automático de Documentación</h2>

<form method="post" action="@Url.Action("Generar", "Home")" id="myForm" name="myForm">
    <label>Ingresa el tema:</label>
    <input type="text" name="inputTexto" class="form-control" required />
    <select name="tipoDiagrama" id="tipoDiagrama">
        <option value="flowchart TB">Flowchart (Top-Bottom)</option>
        <option value="flowchart LR">Flowchart (Left-Right)</option>
        <option value="flowchart RL">Flowchart (Right-Left)</option>
        <option value="flowchart BT">Flowchart (Bottom-Top)</option>
        <option value="sequenceDiagram">Sequence Diagram</option>
        <option value="classDiagram">Class Diagram</option>
        <option value="stateDiagram">State Diagram</option>
        <option value="erDiagram">Entity-Relationship Diagram</option>
        <option value="gantt">Gantt Chart</option>
        <option value="pie">Pie Chart</option>
        <option value="mindmap">Mindmap</option>
        <option value="timeline">Timeline</option>
        <option value="journey">User Journey</option>
        <option value="quadrantChart">Quadrant Chart</option>
    </select>
    <select name="modelo" id="modelo">
        <option value="0">OpenAI</option>
        <option value="1">Ollama</option> 
    </select>
    <button type="submit" class="btn btn-primary mt-2" name="generaPapu" id="generaPapu">Generar</button>
</form>
